# Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ----------------------------------------------------------------------------
# Database — Turso (libSQL) (Required)
# Create a database: https://turso.tech (dashboard) or `turso db create net-trailers`
#   turso db show net-trailers --url        -> TURSO_DATABASE_URL
#   turso db tokens create net-trailers     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# ----------------------------------------------------------------------------
# Auth.js / NextAuth v5 (Required)
# AUTH_SECRET: generate with `npx auth secret` or `openssl rand -base64 32`
AUTH_SECRET=your_auth_secret
# Production URL (omit for local dev). e.g. https://your-app.vercel.app
# AUTH_URL=https://your-domain.com

# GitHub OAuth App (Required for sign-in)
# Create at: https://github.com/settings/developers > New OAuth App
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3000/api/auth/callback/github
#   (add your production callback too: https://your-domain.com/api/auth/callback/github)
AUTH_GITHUB_ID=your_github_oauth_client_id
AUTH_GITHUB_SECRET=your_github_oauth_client_secret

# Admin access (SERVER-SIDE ONLY — not NEXT_PUBLIC_)
# Your GitHub username (login handle). The signed-in user whose GitHub login
# matches this value is treated as admin.
ADMIN_GITHUB_LOGIN=your_github_username

# Email magic-link login (optional — GitHub login works without it)
# Select the email provider: "brevo" (single API key, no domain needed) or
# "resend" (requires a verified domain). Defaults to brevo.
EMAIL_PROVIDER=brevo
# The verified "From" sender address (a Brevo-verified sender, or an address on
# a Resend-verified domain).
EMAIL_FROM=you@example.com
# Brevo transactional API key (when EMAIL_PROVIDER=brevo). Verify a sender first:
# https://app.brevo.com > Senders, Domains & Dedicated IPs > Senders
# Key: https://app.brevo.com > SMTP & API > API Keys  (looks like xkeysib-...)
BREVO_API_KEY=your_brevo_api_key
# Resend API key (when EMAIL_PROVIDER=resend). https://resend.com/api-keys
# (RESEND_API_KEY is also used by the admin email system below.)

# ----------------------------------------------------------------------------
# TMDB API (Required)
# Get your free API key from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key

# Google Gemini AI (Required for Smart Search)
# Get your free API key from: https://ai.google.dev/
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key

# Cron Job Security (Required for auto-updating collections)
CRON_SECRET=your_random_secret_string

# ----------------------------------------------------------------------------
# Account Limits (Optional - defaults to 50)
NEXT_PUBLIC_MAX_TOTAL_ACCOUNTS=50

# App Configuration (Optional)
NEXT_PUBLIC_APP_NAME=NetTrailer
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Sentry Error Monitoring (Optional but recommended for production)
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project

# Google Analytics 4 (Optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Email Notifications (Optional)
# Get from: https://resend.com/
RESEND_API_KEY=your_resend_api_key
# Sender email address (defaults to onboarding@resend.dev if not set)
RESEND_SENDER_EMAIL=noreply@yourdomain.com
